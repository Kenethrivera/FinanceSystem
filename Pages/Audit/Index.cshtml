@page
@model FinanceSystem.Pages.Audit.IndexModel
@{
    ViewData["Title"] = "Audit Trail";
}

<div class="container mt-4" style="max-width: 1000px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Audit Trail</h2>
            <p class="text-muted small mb-0">System activity log and history</p>
        </div>
        <div class="d-none d-md-block">
            <span class="badge bg-light text-secondary border shadow-sm p-2">
                <i class="bi bi-clock-history me-1"></i> Last 100 Actions
            </span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary small text-uppercase">
                        <tr>
                            <th class="py-3 ps-4" style="width: 180px;">Time</th>
                            <th class="py-3" style="width: 200px;">User</th>
                            <th class="py-3" style="width: 120px;">Action</th>
                            <th class="py-3 pe-4">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs)
                        {
                            var displayName = Model.UserNames.ContainsKey(log.Username) ? Model.UserNames[log.Username] : log.Username;
                            var initial = !string.IsNullOrEmpty(displayName) ? displayName.Substring(0, 1).ToUpper() : "?";

                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark">@log.Timestamp.ToString("MMM dd")</span>
                                        <small class="text-muted">@log.Timestamp.ToString("hh:mm tt")</small>
                                    </div>
                                </td>

                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold me-2 shadow-sm"
                                             style="width: 35px; height: 35px; font-size: 0.9rem; border: 2px solid #fff;">
                                            @initial
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-dark" style="font-size: 0.95rem;">@displayName</span>
                                            <small class="text-muted" style="font-size: 0.75rem;">@log.Username</small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    @if (log.Action == "CREATE")
                                    {
                                        <span class="badge bg-success text-white shadow-sm px-3 py-2 rounded-pill border border-success">
                                            <i class="bi bi-plus-lg me-1"></i> CREATE
                                        </span>
                                    }
                                    else if (log.Action == "DELETE")
                                    {
                                        <span class="badge bg-danger text-white shadow-sm px-3 py-2 rounded-pill border border-danger">
                                            <i class="bi bi-trash me-1"></i> DELETE
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary text-white shadow-sm px-3 py-2 rounded-pill border border-primary">
                                            <i class="bi bi-pencil-square me-1"></i> UPDATE
                                        </span>
                                    }
                                </td>

                                <td class="pe-4 text-secondary small">
                                    @log.Details
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>