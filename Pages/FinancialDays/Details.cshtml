@page "{id:long}"
@model FinanceSystem.Pages.FinancialDays.DetailsModel
@{
    ViewData["Title"] = "Transaction Details";
}
<style>
    #imageLightbox .modal-body {
    height: 100vh;
    }

    #imageLightbox .modal-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    margin: auto;
    display: block;
    }

    #imageLightbox .modal-content {
    background-color: rgba(0, 0, 0, 0.95) !important;
    }

    #imageLightbox .modal-body img {
    border-radius: 4px;
    transition: transform 0.3s ease;
    }

    #imageLightbox img {
    max-width: 100%;
    max-height: 100vh;
    width: auto;
    height: auto;
    object-fit: contain;
    margin: auto;
    display: block;
    touch-action: manipulation;
    }
    .liquidation-thumb {
    max-height: 250px;
    width: auto;
    object-fit: contain;
    cursor: zoom-in;
    }

    @@media (max-width: 768px) {
    #imageLightbox .modal-body

    {
    padding: 10px !important;
    }

    }

    body.modal-open {
    overflow: hidden;
    }
</style>

<div class="container mt-4" style="max-width: 1000px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Transaction Details</h2>
            <p class="text-muted small mb-0">Reviewing financial record</p>
        </div>
        <a asp-page="/Index" class="btn btn-outline-secondary border-0">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Day.FlagComment) && string.IsNullOrEmpty(Model.Day.FlagResponse))
    {
        @if ((User.IsInRole("Admin") || User.IsInRole("Auditor")) && !string.IsNullOrEmpty(Model.Day.FlagComment) && string.IsNullOrEmpty(Model.Day.FlagResponse))
        {
            <div class="alert alert-warning border-warning shadow-sm mb-4 rounded-3">
                <div class="d-flex">
                    <div class="me-3"><i class="bi bi-exclamation-triangle-fill fs-3"></i></div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading fw-bold mb-1">Flagged for Review</h5>
                        <p class="mb-2"><strong>Auditor:</strong> "@Model.Day.FlagComment"</p>

                        @if (User.IsInRole("Admin"))
                        {
                            <form method="post" asp-page-handler="ResolveFlag" asp-route-id="@Model.Day.Id" class="mt-2">
                                <div class="input-group">
                                    <input type="text" name="adminResponse" class="form-control border-warning"
                                    placeholder="Write your explanation here..." required />
                                    <button class="btn btn-warning text-dark fw-bold">✅ Resolve & Reply</button>
                                </div>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark border border-dark border-opacity-25">Waiting for Admin Response...</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
    @if (Model.IsMonthLocked)
{
    <div class="alert alert-success">
        <strong><i class="bi bi-patch-check-fill"></i> Final and Audited</strong><br />
        This record belongs to a locked month. It can no longer be edited, deleted, or flagged.
    </div>
}

    @if ((User.IsInRole("Admin") || User.IsInRole("Auditor")) && !string.IsNullOrEmpty(Model.Day.FlagComment) && !string.IsNullOrEmpty(Model.Day.FlagResponse))
    {
        <div class="alert alert-success border-success shadow-sm mb-4 rounded-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="alert-heading fw-bold mb-0"><i class="bi bi-check-circle-fill me-2"></i>Resolved</h5>
                <span class="badge bg-success bg-opacity-10 text-success border border-success">Issue Closed</span>
            </div>
            <hr class="my-2 border-success opacity-25">
            <div class="ps-3 border-start border-3 border-success border-opacity-25">
                <p class="mb-1 text-muted small">Auditor asked:</p>
                <p class="fst-italic text-secondary mb-2">"@Model.Day.FlagComment"</p>
                <p class="mb-1 text-success fw-bold">Admin Responded:</p>
                <p class="mb-0">"@Model.Day.FlagResponse"</p>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start">

                <div class="mb-3 mb-md-0">
                    <h4 class="fw-bold text-primary mb-1">
                        @Model.Day.Activity_Date.ToString("MMMM dd, yyyy")
                    </h4>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-calendar-event me-1"></i> @Model.Day.Activity_Date.DayOfWeek
                        </span>
                        @if (Model.Day.Is_Sunday)
                        {
                            <span class="badge bg-primary text-white border border-primary">Sunday Service</span>
                        }
                        else
                        {
                            <span class="badge bg-white text-dark border">Activity</span>
                        }
                    </div>
                </div>

                <div class="text-md-end">
                    <p class="text-muted small mb-0 font-monospace">
                        ID: #@Model.Day.Activity_Date.ToString("yyyyMMdd")_@Model.Day.Id
                    </p>
                </div>
            </div>

            <hr class="my-4 text-muted opacity-25">

            <div>
                @if (User.IsInRole("Admin"))
                {
                    <form method="post" asp-page-handler="UpdateNotes" asp-route-id="@Model.Day.Id">
                        <label class="small text-muted fw-bold mb-1">NOTES / DESCRIPTION</label>
                        <div class="input-group">
                            <input type="text" name="newNotes" class="form-control bg-light border-0" value="@Model.Day.Notes" />
                            <button type="submit" class="btn btn-outline-primary border-0 bg-light fw-bold">Save</button>
                        </div>
                    </form>
                }
                else
                {
                    <label class="small text-muted fw-bold mb-1">NOTES</label>
                    <p class="mb-0 fs-5">@(Model.Day.Notes ?? "No notes provided")</p>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom bg-white rounded-top">
                        <h6 class="fw-bold text-success mb-0">
                            <i class="bi bi-arrow-down-circle-fill me-2"></i>Money In (Income)
                        </h6>
                    </div>
                    <ul class="list-group list-group-flush">
                        @foreach (var b in Model.Budgets)
                        {
                            var sName = Model.Sources.FirstOrDefault(s => s.Id == b.Source_Id)?.Name ?? "Unknown";
                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold text-dark">@sName</div>
                                        @if (!string.IsNullOrEmpty(b.Notes))
                                        {
                                            <small class="text-muted">@b.Notes</small>
                                        }
                                    </div>
                                    <span class="text-success fw-bold fs-5">+@b.Amount.ToString("N2")</span>
                                </div>
                            </li>
                        }
                        @if (Model.Offerings.Any())
                        {
                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold text-dark">Tithes & Offerings</div>
                                        <small class="text-muted">Total Breakdown</small>
                                    </div>
                                    <span class="text-success fw-bold fs-5">+@Model.Offerings.Sum(o => o.Total).ToString("N2")</span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom bg-white rounded-top">
                        <h6 class="fw-bold text-danger mb-0">
                            <i class="bi bi-arrow-up-circle-fill me-2"></i>Money Out (Expenses)
                        </h6>
                    </div>
                    <ul class="list-group list-group-flush">
                        @if (!Model.Expenses.Any())
                        {
                            <li class="list-group-item py-4 text-center text-muted fst-italic">
                                No expenses recorded for this day.
                            </li>
                        }

                        @foreach (var e in Model.Expenses)
                        {
                            var cName = Model.Categories.FirstOrDefault(c => c.Id == e.Category_Id)?.Name ?? "Expense";
                            var sName = Model.Sources.FirstOrDefault(s => s.Id == e.Source_Id)?.Name ?? "Cash On Hand";

                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold text-dark">@cName</span>
                                    <span class="text-danger fw-bold">-@e.Amount.ToString("N2")</span>
                                </div>
                                <div class="d-flex justify-content-between mt-1">
                                    <small class="text-muted">@e.Notes</small>
                                    <small class="text-muted fst-italic" style="font-size: 0.75rem;">Paid via: @sName</small>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body p-4">
                <h6 class="fw-bold text-warning text-dark mb-3">
                    <i class="bi bi-file-earmark-spreadsheet-fill me-2"></i>Mother Church Liquidation
                </h6>
                <div class="row">
                    <div class="col-md-6">
                        @if (Model.Liquidation == null)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="text-center py-4 bg-light rounded border border-dashed">
                                    <i class="bi bi-camera display-4 text-muted mb-3 d-block"></i>
                                    <p class="mb-3 text-muted">Upload photo of signed form</p>

                                    <form method="post" enctype="multipart/form-data" asp-page-handler="UploadLiquidation" class="px-4">
                                        <input type="hidden" name="id" value="@Model.Day.Id" />
                                        <input type="file" name="uploadFile" class="form-control mb-2" accept="image/*" required />
                                        <button class="btn btn-dark w-100">Upload Report</button>
                                    </form>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center">
                                <div class="text-center">
                                    <button type="button" class="btn p-0 border-0 shadow-sm rounded overflow-hidden" data-bs-toggle="modal" data-bs-target="#imageLightbox">
                                        <img src="https://zqaiekguutvjnjnsbflp.supabase.co/storage/v1/object/public/liquidation-proofs/@Model.Liquidation.ImagePath"
                                             class="img-fluid liquidation-thumb shadow-sm"
                                             alt="Liquidation Proof" />
                                    </button>
                                    <p class="text-muted small mt-2">
                                        <i class="bi bi-check-circle-fill text-success me-1"></i> File Uploaded
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    

    @if (User.IsInRole("Auditor") && string.IsNullOrEmpty(Model.Day.FlagComment))
    {
        <div class="card bg-light border-0 shadow-sm mt-4">
            <div class="card-body p-3">
                <form method="post" asp-page-handler="FlagRecord" asp-route-id="@Model.Day.Id" class="row align-items-center g-2">
                    <div class="col-auto">
                        <span class="fw-bold text-muted small text-uppercase"><i class="bi bi-shield-exclamation me-1"></i>Auditor:</span>
                    </div>
                    <div class="col">
                        <input type="text" name="comment" class="form-control" placeholder="Flag an issue with this record..." required />
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-warning fw-bold">Flag Record</button>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (User.IsInRole("Admin"))
    {
        <div class="mt-5 mb-5 pt-4 border-top">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-danger fw-bold mb-1">Danger Zone</h6>
                    <p class="text-muted small mb-0">Permanently delete this entire record and its transactions.</p>
                </div>

                <button type="button" class="btn btn-outline-danger btn-sm fw-bold px-3" data-bs-toggle="modal" data-bs-target="#deleteConfirmModal">
                    <i class="bi bi-trash me-1"></i> Delete Record
                </button>
            </div>
        </div>

        <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-bottom-0">
                        <h5 class="modal-title fw-bold text-dark" id="deleteConfirmModalLabel">Confirm Deletion</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center py-4">
                        <div class="text-danger mb-3">
                            <i class="bi bi-exclamation-octagon-fill" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="fw-bold">Are you sure?</h5>
                        <p class="text-muted mb-0">You are about to delete the record for <strong>@Model.Day.Activity_Date.ToString("MMMM dd, yyyy")</strong>.</p>
                        <p class="text-danger small fw-bold mt-2">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer border-top-0 d-flex justify-content-center pb-4">
                        <button type="button" class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal">No, Keep it</button>

                        <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Day.Id">
                            <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">
                                Yes, Delete Permanently
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    }


        @if (Model.Liquidation != null)
        {
            <div class="modal fade" id="imageLightbox" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-fullscreen modal-dialog-centered">
                    <div class="modal-content bg-black border-0">
                        <div class="position-absolute top-0 end-0 p-3" style="z-index: 1055;">
                            <button type="button" class="btn btn-link text-white text-decoration-none fs-2" data-bs-dismiss="modal">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>  

                        <div class="modal-body d-flex align-items-center justify-content-center p-0">
                            <img src="https://zqaiekguutvjnjnsbflp.supabase.co/storage/v1/object/public/liquidation-proofs/@Model.Liquidation.ImagePath"
                                 class="img-fluid modal-image shadow-lg"/>
                        </div>

                        <div class="modal-footer border-0 position-absolute bottom-0 w-100 justify-content-center bg-dark bg-opacity-50">
                            <p class="text-white small mb-0">
                                Liquidation Proof - @Model.Day.Activity_Date.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }

    

</div>