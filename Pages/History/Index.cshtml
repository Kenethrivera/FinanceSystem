@page
@model FinanceSystem.Pages.History.IndexModel
@{
    ViewData["Title"] = "Transaction History";
}

<div class="container mt-4" style="max-width: 1000px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">History</h2>
            <p class="text-muted small mb-0">Search and review past financial records</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-9 col-lg-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted ps-3"><i class="bi bi-search"></i></span>
                        <input type="text" name="SearchTerm" value="@Model.SearchTerm"
                               class="form-control border-start-0 ps-0 py-2"
                               placeholder="Search notes (e.g. 'Fellowship', 'Rent')..." />
                    </div>
                </div>
                <div class="col-md-3 col-lg-2 d-grid gap-2 d-flex">
                    <button type="submit" class="btn btn-primary fw-bold flex-grow-1">Search</button>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <a asp-page="./Index" class="btn btn-light border text-muted" title="Clear Search">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3" style="min-width: 150px;">Date</th>
                            <th class="py-3" style="min-width: 200px;">Description</th>
                            <th class="text-center py-3" style="min-width: 120px;">Status</th>
                            <th class="text-end pe-4 py-3" style="min-width: 100px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in Model.Days)
                        {
                            <tr>
                                <td class="ps-4 text-nowrap">
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark">@day.Activity_Date.ToString("MMM dd, yyyy")</span>
                                        <small class="text-muted">@day.Activity_Date.ToString("dddd")</small>
                                    </div>
                                </td>

                                <td>
                                    @if (string.IsNullOrEmpty(day.Notes))
                                    {
                                        <span class="text-muted fst-italic small">No notes provided</span>
                                    }
                                    else
                                    {
                                        <span class="text-dark">@day.Notes</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(day.FlagComment) && string.IsNullOrEmpty(day.FlagResponse))
                                    {
                                        <span class="badge bg-warning text-dark border border-warning shadow-sm px-3 py-2 rounded-pill">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Flagged
                                        </span>
                                    }
                                    else if (!string.IsNullOrEmpty(day.FlagResponse))
                                    {
                                        <span class="badge bg-success text-white shadow-sm px-3 py-2 rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1"></i> Resolved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill">
                                            Normal
                                        </span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <a asp-page="/FinancialDays/Details" asp-route-id="@day.Id" class="btn btn-sm btn-light text-primary fw-bold border shadow-sm">
                                        View <i class="bi bi-chevron-right small ms-1"></i>
                                    </a>
                                </td>
                            </tr>
                        }

                        @if (Model.Days.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="text-muted opacity-50 mb-2">
                                        <i class="bi bi-folder2-open display-4"></i>
                                    </div>
                                    <p class="text-muted fw-bold mb-0">No records found</p>
                                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                    {
                                        <small class="text-muted">Try adjusting your search for "<strong>@Model.SearchTerm</strong>"</small>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white py-3 border-0 border-top d-flex justify-content-between align-items-center">
            @if (Model.CurrentPage > 1)
            {
                <a asp-page="./Index" asp-route-CurrentPage="@(Model.CurrentPage - 1)" asp-route-SearchTerm="@Model.SearchTerm"
                   class="btn btn-outline-secondary btn-sm px-3 fw-bold">
                    <i class="bi bi-chevron-left small me-1"></i> Previous
                </a>
            }
            else
            {
                <button class="btn btn-outline-light text-muted btn-sm px-3 fw-bold border" disabled>Previous</button>
            }

            <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">Page @Model.CurrentPage</span>

            @if (Model.Days.Count == Model.PageSize)
            {
                <a asp-page="./Index" asp-route-CurrentPage="@(Model.CurrentPage + 1)" asp-route-SearchTerm="@Model.SearchTerm"
                   class="btn btn-outline-primary btn-sm px-4 fw-bold shadow-sm">
                    Next <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            }
            else
            {
                <button class="btn btn-outline-light text-muted btn-sm px-4 fw-bold border" disabled>Next</button>
            }
        </div>
    </div>

</div>