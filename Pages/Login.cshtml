@page
@model FinanceSystem.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PFC Finance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            /* Changed to 'scroll' for better mobile support */
            background: url('/images/login-bg.jpg') no-repeat center center scroll;
            background-size: cover;
            /* use min-height to handle mobile keyboard popups */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
        }

        /* The dark overlay */
        .overlay {
            position: fixed; /* Fixed covers screen even when scrolling */
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 50, 100, 0.65);
            z-index: 1;
        }

        /* The Login Card */
        .login-card {
            position: relative;
            z-index: 2;
            /* MOBILE WIDTH SETTINGS */
            width: 85%; /* Sets card to 85% of screen width on mobile */
            max-width: 400px; /* Stops it from getting too big on desktop */

            border-radius: 15px;
            border: none;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            overflow: visible; /* Changed to visible so logo can overlap if needed */
        }

        /* Responsive tweak: If you strictly want 60% on mobile, uncomment below
                   But warning: inputs will be very small on phones! */
        /* @@media (max-width: 576px) {
            .login-card

        {
            width: 60%;
        }

        }

        */

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }

        /* Smooth animation for entry */
        .animate-fade-in {
            animation: fadeInUp 0.5s ease-out;
        }

        @@keyframes fadeInUp {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>
</head>

<body>

    <div class="overlay"></div>

    <div class="login-card p-4 pt-5 animate-fade-in">

        <div class="text-center mb-4">
            <img src="~/images/pfc-logo.jpg"
                 alt="PFC Logo"
                 class="rounded-circle shadow-sm mb-3"
                 style="width: 110px; height: 110px; object-fit: cover; border: 3px solid white;">

            <h4 class="fw-bold text-dark mb-0">Stewardship Ministry</h4>
            <small class="text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Pinagpala Family Center</small>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger text-center py-2 shadow-sm border-0">
                <i class="bi bi-exclamation-circle-fill me-1"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="form-floating mb-3">
                <input type="text" asp-for="Username" class="form-control" id="floatingInput" placeholder="Username" required autofocus />
                <label for="floatingInput" class="text-muted">Username</label>
            </div>

            <div class="form-floating mb-4">
                <input type="password" asp-for="Password" class="form-control" id="floatingPassword" placeholder="Password" required />
                <label for="floatingPassword" class="text-muted">Password</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" style="border-radius: 10px;">
                SIGN IN
            </button>
        </form>

        <div class="text-center mt-4 mb-2">
            <small class="text-muted opacity-75">Authorized Personnel Only</small>
        </div>
    </div>

</body>
</html>