@page
@model FinanceSystem.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PFC Finance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            /* Set the background image */
            background: url('/images/login-bg.jpg') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* The dark overlay to make text readable */
        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 50, 100, 0.65); /* Blue tint overlay */
            z-index: 1;
        }

        /* The Login Card */
        .login-card {
            position: relative;
            z-index: 2; /* Sits on top of overlay */
            width: 100%;
            max-width: 400px;
            border-radius: 15px;
            border: none;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            background: rgba(255, 255, 255, 0.95); /* Slightly transparent white */
            backdrop-filter: blur(10px); /* Glass blur effect */
            overflow: hidden;
        }

        .logo-container {
            width: 100px;
            height: 100px;
            margin: -50px auto 20px; /* Pulls logo up */
            background: white;
            border-radius: 50%;
            padding: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-img {
            max-width: 100%;
            height: auto;
        }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }
    </style>
</head>

<body>

    <div class="overlay"></div>

    <div class="container px-4">
        <div class="login-card mx-auto p-4 pt-5 animate-fade-in">

            <div class="text-center mb-4">
                <img src="~/images/pfc-logo.jpg"
                     alt="PFC Logo"
                     class="rounded-circle shadow-sm mb-3"
                     style="width: 110px; height: 110px; object-fit: cover; border: 3px solid white;">

                <h4 class="fw-bold text-dark mb-0">Stewardship Ministry</h4>
                <small class="text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Pinagpala Family Center</small>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger text-center py-2 shadow-sm border-0">
                    <i class="bi bi-exclamation-circle-fill me-1"></i> @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="form-floating mb-3">
                    <input type="text" asp-for="Username" class="form-control" id="floatingInput" placeholder="Username" required autofocus />
                    <label for="floatingInput" class="text-muted">Username</label>
                </div>

                <div class="form-floating mb-4">
                    <input type="password" asp-for="Password" class="form-control" id="floatingPassword" placeholder="Password" required />
                    <label for="floatingPassword" class="text-muted">Password</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" style="border-radius: 10px;">
                    SIGN IN
                </button>
            </form>

            <div class="text-center mt-4 mb-2">
                <small class="text-muted opacity-75">Authorized Personel Only</small>
            </div>
        </div>
    </div>

</body>
</html>