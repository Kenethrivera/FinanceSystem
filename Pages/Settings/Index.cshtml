@page
@model FinanceSystem.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "System Settings";
}

<style>
    .confirm-delete-actions {
        display: none;
    }

    .confirm-delete .confirm-delete-actions {
        display: block;
    }

    .confirm-delete .delete-btn {
        display: none;
    }
</style>

<div class="container mt-4" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">System Settings</h2>
            <p class="text-muted small mb-0">Manage your financial categories and wallets</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- ================= INCOME ================= -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom border-success border-opacity-25">
                    <h6 class="fw-bold mb-0">Income Labels</h6>
                </div>
                <div class="card-body">

                    <form method="post" asp-page-handler="AddIncomeCategory" class="mb-3">
                        <div class="input-group">
                            <input type="text" name="name" class="form-control bg-light border-0" placeholder="New Label..." required />
                            <button class="btn btn-success fw-bold">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </form>

                    @foreach (var cat in Model.IncomeCategories)
                    {
                        <div class="list-group-item rounded mb-1 bg-light px-2 py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-secondary">@cat.Name</span>

                                <button type="button"
                                        class="btn btn-sm btn-light text-danger border-0 delete-btn"
                                        onclick="this.closest('.list-group-item').classList.toggle('confirm-delete')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>

                            <div class="confirm-delete-actions mt-2">
                                <form method="post"
                                      asp-page-handler="DeleteCategory"
                                      asp-route-id="@cat.Id"
                                      class="d-inline">
                                    <button class="btn btn-sm btn-danger">Confirm</button>
                                </form>
                                <button type="button"
                                        class="btn btn-sm btn-secondary"
                                        onclick="this.closest('.list-group-item').classList.toggle('confirm-delete')">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ================= EXPENSE ================= -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom border-danger border-opacity-25">
                    <h6 class="fw-bold mb-0">Expense Labels</h6>
                </div>
                <div class="card-body">

                    <form method="post" asp-page-handler="AddCategory" class="mb-3">
                        <div class="input-group">
                            <input type="text" name="name" class="form-control bg-light border-0" placeholder="New Category..." required />
                            <button class="btn btn-danger fw-bold">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </form>

                    @foreach (var cat in Model.ExpenseCategories)
                    {
                        <div class="list-group-item rounded mb-1 bg-light px-2 py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-secondary">@cat.Name</span>

                                <button type="button"
                                        class="btn btn-sm btn-light text-danger border-0 delete-btn"
                                        onclick="this.closest('.list-group-item').classList.toggle('confirm-delete')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>

                            <div class="confirm-delete-actions mt-2">
                                <form method="post"
                                      asp-page-handler="DeleteCategory"
                                      asp-route-id="@cat.Id"
                                      class="d-inline">
                                    <button class="btn btn-sm btn-danger">Confirm</button>
                                </form>
                                <button type="button"
                                        class="btn btn-sm btn-secondary"
                                        onclick="this.closest('.list-group-item').classList.toggle('confirm-delete')">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ================= WALLETS ================= -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom border-primary border-opacity-25">
                    <h6 class="fw-bold mb-0">Wallets / Sources</h6>
                </div>
                <div class="card-body">

                    <form method="post" asp-page-handler="AddSource" class="mb-4">
                        <input type="text" name="name" class="form-control mb-2 bg-light border-0" placeholder="Wallet Name..." required />
                        <div class="input-group">
                            <input type="text" name="description" class="form-control bg-light border-0" placeholder="Description (Optional)" />
                            <button class="btn btn-primary fw-bold">Add</button>
                        </div>
                    </form>

                    @foreach (var src in Model.Sources)
                    {
                        <div class="list-group-item rounded mb-2 bg-light px-3 py-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold">@src.Name</div>
                                    @if (!string.IsNullOrEmpty(src.Description))
                                    {
                                        <small class="text-muted">@src.Description</small>
                                    }
                                </div>

                                <button type="button"
                                        class="btn btn-sm btn-light text-danger delete-btn"
                                        onclick="this.closest('.list-group-item').classList.toggle('confirm-delete')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>

                            <div class="confirm-delete-actions mt-2">
                                <form method="post"
                                      asp-page-handler="DeleteSource"
                                      asp-route-id="@src.Id"
                                      class="d-inline">
                                    <button class="btn btn-sm btn-danger">Confirm</button>
                                </form>
                                <button type="button"
                                        class="btn btn-sm btn-secondary"
                                        onclick="this.closest('.list-group-item').classList.toggle('confirm-delete')">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>
