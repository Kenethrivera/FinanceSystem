<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="manifest" href="~/manifest.json">
    <meta name="theme-color" content="#0d6efd">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', sans-serif;
        }

            /* FIX: Prevents background scrolling when sidebar is open on phone */
            body.sidebar-open {
                overflow: hidden;
            }

        :root {
            --brand-blue: #0d6efd;
        }

        .bg-primary {
            background-color: var(--brand-blue) !important;
        }

        .text-primary {
            color: var(--brand-blue) !important;
        }

        /* --- SIDEBAR STYLES --- */
        .sidebar {
            width: 260px;
            background: #212529;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1050; /* Higher than navbar */
            transition: transform 0.3s ease-in-out;
            overflow-y: auto; /* Enable vertical scrolling inside sidebar */
            -webkit-overflow-scrolling: touch; /* Smooth scroll on iOS */
            scrollbar-width: thin;
        }

        .main-content {
            margin-left: 260px;
            transition: all 0.3s;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        /* Sidebar Links */
        .nav-link {
            color: rgba(255,255,255,0.75);
            padding: 10px 15px;
            margin-bottom: 5px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .nav-link:hover {
                color: #fff;
                background: rgba(255,255,255,0.1);
                transform: translateX(5px);
            }

            .nav-link.active {
                background: var(--brand-blue);
                color: white;
                box-shadow: 0 4px 10px rgba(13,110,253,0.4);
                font-weight: 600;
            }

            .nav-link i {
                margin-right: 10px;
                font-size: 1.1rem;
            }

        /* --- MOBILE ADJUSTMENTS --- */
        @@media (max-width: 768px) {
            .sidebar

        {
            transform: translateX(-100%); /* Hidden by default */
            width: 280px;
            box-shadow: none;
        }

        .sidebar.active {
            transform: translateX(0); /* Slide in */
            box-shadow: 5px 0 15px rgba(0,0,0,0.5);
        }

        .main-content {
            margin-left: 0;
            width: 100%;
            padding-top: 70px !important; /* Push content down so header doesn't cover it */
        }

        /* Overlay for mobile */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0,0,0,0.5);
            z-index: 1040;
            backdrop-filter: blur(2px);
        }

            .sidebar-overlay.active {
                display: block;
            }

        }
    </style>
</head>
<body>

    <nav class="navbar navbar-dark bg-primary d-md-none fixed-top shadow px-3" style="height: 60px;">
        <div class="d-flex align-items-center w-100">
            <button class="btn btn-link text-white p-0 me-3 border-0" id="sidebarToggle">
                <i class="bi bi-list fs-1"></i>
            </button>
            <a class="navbar-brand fw-bold d-flex align-items-center me-0" href="#">
                <img src="~/images/pfc-logo.jpg" width="35" height="35" class="rounded-circle me-2 border border-white">
                <span>Finance</span>
            </a>
        </div>
    </nav>

    <div class="sidebar-overlay" id="overlay"></div>

    <div class="d-flex">
        <div class="sidebar d-flex flex-column p-3 text-white" id="sidebar">
            <div class="d-flex align-items-center justify-content-between mb-4 mt-2 px-2">
                <a href="/" class="d-flex align-items-center text-white text-decoration-none">
                    <img src="~/images/pfc-logo.jpg" class="rounded-circle me-3 border border-2 border-white" width="45" height="45">
                    <div>
                        <div class="fw-bold fs-5">Finance</div>
                        <small class="text-white-50" style="font-size: 0.75rem;">Pinagpala Family Center</small>
                    </div>
                </a>
                <button class="btn btn-sm btn-outline-secondary d-md-none text-white-50 border-0" id="sidebarClose">
                    <i class="bi bi-x-lg fs-5"></i>
                </button>
            </div>

            <hr class="text-white-50 my-2">

            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-page="/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/Reports/Monthly" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Reports/Monthly" ? "active" : "")">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i> Reports
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/Reports/MemberHistory" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Reports/MemberHistory" ? "active" : "")">
                        <i class="bi bi-people-fill"></i> Giving History
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/History/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/History") == true ? "active" : "")">
                        <i class="bi bi-clock-history"></i> History
                    </a>
                </li>

                @if (User.IsInRole("Pastor"))
                {
                    <li class="nav-item mt-2">
                        <a asp-page="/Requests/Index" class="btn btn-primary w-100 fw-bold shadow-sm py-2" style="border-radius: 30px;">
                            <i class="bi bi-send-plus"></i> Fund Request
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a asp-page="/Admin/Requests"
                           class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Requests" ? "active" : "text-white-50")">
                            <i class="bi bi-inbox"></i> Review Requests
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="mt-4 mb-2 px-2 text-uppercase text-white-50 fw-bold small" style="font-size: 0.7rem; letter-spacing: 1px;">Admin Actions</li>
                    <li class="mb-2 px-2">
                        <a asp-page="/FinancialDays/Add" class="btn btn-primary w-100 fw-bold shadow-sm py-2" style="border-radius: 30px;">
                            <i class="bi bi-plus-lg me-1"></i> New Entry
                        </a>
                    </li>

                    <li class="nav-item mt-1">
                        <a asp-page="/Settings/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Settings") == true ? "active" : "text-white-50")">
                            <i class="bi bi-sliders"></i> Settings
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Auditor"))
                {
                    <li class="nav-item">
                        <a asp-page="/Audit/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Audit") == true ? "active" : "text-white-50")">
                            <i class="bi bi-shield-check"></i> Audit Trail
                        </a>
                    </li>
                }
            </ul>

            <hr class="text-white-50">

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle p-2 rounded hover-bg-dark" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm" style="width:38px; height:38px; font-weight:bold;">
                        @User.FindFirst("FullName")?.Value.Substring(0, 1).ToUpper()
                    </div>
                    <div class="lh-1 me-2">
                        <div class="fw-bold small">@User.FindFirst("FullName")?.Value</div>
                        <small class="text-white-50" style="font-size: 0.7rem;">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                    </div>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark shadow-lg border-0" aria-labelledby="dropdownUser1">
                    <li><a class="dropdown-item" asp-page="/Profile/Index">My Profile</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" asp-page="/Logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                </ul>
            </div>

            <div class="d-md-none" style="height: 50px;"></div>
        </div>

        <div class="main-content bg-light">
            <div class="container-fluid p-3 p-md-4 pt-md-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            // Function to handle sidebar toggle
            function toggleSidebar() {
                $('#sidebar').toggleClass('active');
                $('#overlay').toggleClass('active');

                // CRITICAL: Lock body scroll to prevent background scrolling
                $('body').toggleClass('sidebar-open');
            }

            // Click Handler for Hamburger
            $('#sidebarToggle').on('click', function (e) {
                e.stopPropagation();
                toggleSidebar();
            });

            // Click Handler for Overlay (Close)
            $('#overlay').on('click', function () {
                toggleSidebar();
            });

            // Click Handler for Close Button (Sidebar)
            $('#sidebarClose').on('click', function () {
                toggleSidebar();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>