@page
@model FinanceSystem.Pages.SmartScan.IndexModel
@{
    ViewData["Title"] = "Smart Envelope Scan";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Smart Envelope Scan</h2>
        <p class="text-muted mb-0">Upload one envelope slip image and extract the member giving details.</p>
    </div>
    <a asp-page="/FinancialDays/Add" class="btn btn-outline-secondary">Back to New Entry</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">1. Upload Slip Image</h5>

                <form method="post" enctype="multipart/form-data" asp-page-handler="Extract">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Envelope Slip Image</label>
                        <input asp-for="Upload" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text">Use a clear, straight photo of one slip only.</div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Extract Details
                    </button>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.UploadedImageUrl))
                {
                    <hr />
                    <h6 class="fw-bold mb-2">Uploaded Image</h6>
                    <img src="@Model.UploadedImageUrl" class="img-fluid rounded border" alt="Uploaded slip preview" />
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">2. Review Extracted Values</h5>

                @if (Model.HasResult)
                {
                    <form method="post" asp-page-handler="Confirm">
                        <input asp-for="Result.RawText" type="hidden" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Name</label>
                                <input asp-for="Result.Name" class="form-control" />
                            </div>
                            <div>
                                <input asp-for="Result.DateText" type="hidden" />
                            </div>
                                 
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Tithes</label>
                                <input asp-for="Result.Tithes" class="form-control" type="number" step="0.01" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Offering</label>
                                <input asp-for="Result.Offering" class="form-control" type="number" step="0.01" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Solomon</label>
                                <input asp-for="Result.Solomon" class="form-control" type="number" step="0.01" />
                            </div>

                            <div class="col-12">
                                <div class="p-3 rounded bg-light border">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold">Total</span>
                                        <span class="fw-bold text-primary">₱ @Model.Result.Total.ToString("N2")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Raw OCR Text</label>
                                <textarea asp-for="Result.RawText" class="form-control" rows="8"></textarea>
                            </div>

                            <div class="col-12 d-flex gap-2">
                                <button type="submit" class="btn btn-success">
                                    Confirm and Send to New Entry
                                </button>

                                <a asp-page="/SmartScan/Index" class="btn btn-outline-secondary">
                                    Scan Another
                                </a>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <div class="text-muted">
                        No extracted result yet.
                    </div>
                }
            </div>
        </div>
    </div>
</div>